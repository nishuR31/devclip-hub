NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas — https://cloud.mongodb.com
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/devclipboard?retryWrites=true&w=majority

# ── Cache / Queues ────────────────────────────────────────────────────────────
# Redis — local or Upstash (https://upstash.com)
REDIS_URL=redis://localhost:6379

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_with_64_char_hex
REFRESH_TOKEN_SECRET=replace_with_64_char_hex
TWO_FACTOR_TOKEN_SECRET=replace_with_64_char_hex
# AES-256 key for encrypting TOTP secrets at rest
TOTP_ENCRYPTION_KEY=replace_with_64_char_hex

# ── Email — Gmail SMTP ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Enable 2FA on your Google account, then create an App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_FROM=your-address@gmail.com
EMAIL_FROM_NAME=DevClipboard Hub
EMAIL_FROM_PASS=xxxx_xxxx_xxxx_xxxx

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com
# Use test keys (rzp_test_*) during development; switch to live keys in production.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret — set in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Create subscription plans in Razorpay Dashboard → Products → Plans
# Amounts must be in paise (e.g. Rs299/mo = 29900 paise)
RAZORPAY_STARTER_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_STARTER_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PRO_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_PRO_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_TEAM_MONTHLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_TEAM_YEARLY_PLAN_ID=plan_xxxxxxxxxxxxxxxxxxxx

# Public plan prices returned by /api/subscriptions/plans (in paise)
PLAN_FREE_MONTHLY_INR_PAISE=0
PLAN_FREE_YEARLY_INR_PAISE=0
PLAN_STARTER_MONTHLY_INR_PAISE=29900
PLAN_STARTER_YEARLY_INR_PAISE=249900
PLAN_PRO_MONTHLY_INR_PAISE=59900
PLAN_PRO_YEARLY_INR_PAISE=499900
PLAN_TEAM_MONTHLY_INR_PAISE=149900
PLAN_TEAM_YEARLY_INR_PAISE=1199900

# ── Misc ──────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_EXPIRES_SECONDS=600
MAGIC_LINK_EXPIRES_SECONDS=900
