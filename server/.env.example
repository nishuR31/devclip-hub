NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:8080

# MongoDB Atlas - get from https://cloud.mongodb.com
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/devclipboard?retryWrites=true&w=majority

# Redis - local or Upstash (https://upstash.com)
REDIS_URL=redis://localhost:6379

# JWT secrets - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=replace_with_64_char_hex
REFRESH_TOKEN_SECRET=replace_with_64_char_hex
TWO_FACTOR_TOKEN_SECRET=replace_with_64_char_hex
# AES-256 key for encrypting TOTP secrets at rest
TOTP_ENCRYPTION_KEY=replace_with_64_char_hex

# Email - Resend.com (free tier = 100 emails/day) https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=DevClipboard Hub

# Stripe - https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Stripe Price IDs (monthly INR amounts in paise: ₹299 = 29900)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxxx
STRIPE_STARTER_YEARLY_PRICE_ID=price_xxxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxx
STRIPE_TEAM_MONTHLY_PRICE_ID=price_xxxx
STRIPE_TEAM_YEARLY_PRICE_ID=price_xxxx

BCRYPT_ROUNDS=12
OTP_EXPIRES_SECONDS=600
MAGIC_LINK_EXPIRES_SECONDS=900
